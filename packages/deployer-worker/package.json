{
  "name": "@hermes/deployer-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./db": "./src/db.ts",
    "./secrets": "./src/secrets.ts",
    "./ws-auth": "./src/ws-auth.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:dev": "tsx watch bin/main.ts",
    "worker:start": "tsx bin/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hermes/provisioner": "workspace:*",
    "@prisma/client": "^6.2.0",
    "dockerode": "^4.0.2",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.13",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
