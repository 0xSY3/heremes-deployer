# The ONE shared platform bot, created once via @BotFather (display name
# "Hermes Zynd"). All tenants connect to this single bot — end users never
# create their own bot. Keep the token secret; it is gitignored in .env.
TELEGRAM_BOT_TOKEN=000000000:replace-with-the-real-botfather-token
TELEGRAM_BOT_USERNAME=HermesZyndBot

# Shared with the web app: the deep-link connect tokens the dashboard mints and
# the gateway consumes live in this JSON file (repo root by default).
HERMES_CONNECT_TOKENS_PATH=../../.telegram-connect-tokens.json
# Persistent map of Telegram chat -> tenant (who is linked to which agent).
HERMES_CHAT_LINKS_PATH=../../.telegram-chat-links.json
# Shared agent registry (same file the provisioner/web use).
HERMES_STORE_PATH=../../.agent-store.json

# Model the gateway asks each agent to use for /v1/chat/completions. The agent
# also has its own default; this is just what we put in the request body.
HERMES_GATEWAY_MODEL=hermes

# How the gateway receives updates: "polling" (local dev, no public URL needed)
# or "webhook" (production; set TELEGRAM_WEBHOOK_URL and run set-webhook).
TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_URL=https://gateway.zynd.example.com/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=generate-a-random-secret
