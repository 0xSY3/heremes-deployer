{
  "name": "@hermes/provisioner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./presets": "./src/presets.ts",
    "./local": "./src/local/local-deps.ts",
    "./aws": "./src/clients.ts",
    "./supabase": "./src/supabase-store.ts",
    "./dynamo": "./src/dynamo-store.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "provision": "tsx bin/provision.ts",
    "teardown": "tsx bin/teardown.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1062.0",
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/client-efs": "^3.700.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.1062.0",
    "@supabase/supabase-js": "^2.107.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
