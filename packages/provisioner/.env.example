# Shared infra IDs (M0 consumes these; does NOT create them)
AWS_REGION=us-east-1
ECS_CLUSTER=hermes-agents
SUBNET_IDS=subnet-aaaa,subnet-bbbb           # private subnets (awsvpc)
EFS_FILESYSTEM_ID=fs-0123456789abcdef0
ALB_LISTENER_ARN=arn:aws:elasticloadbalancing:us-east-1:111111111111:listener/app/hermes/abc/def
ALB_VPC_ID=vpc-0123456789abcdef0
VPC_CIDR=10.0.0.0/16                          # scopes the EFS NFS (2049) egress rule to in-VPC mount targets
CERT_DOMAIN=agents.example.com               # wildcard *.agents.example.com on the listener
EXECUTION_ROLE_ARN=arn:aws:iam::111111111111:role/hermes-task-execution
TASK_ROLE_ARN=arn:aws:iam::111111111111:role/hermes-task
HERMES_IMAGE=nousresearch/hermes-agent:v2026.5.29.2
