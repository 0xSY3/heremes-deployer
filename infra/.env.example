# Hermes Deployer — environment. Copy to /etc/hermes-deployer/{web,worker}.env.
# Both processes share DATABASE_URL + DEPLOYER_WS_SECRET; the worker adds the
# Docker/Caddy/loop knobs. NOTE: there is NO HOST_DATA_ROOT — Hermes containers
# take their whole config from env (no bind mounts), so no path translation.

# --- shared ---
DATABASE_URL=postgresql://hermes:hermes@localhost:5432/hermes_deployer?schema=public
NODE_ENV=production
DEPLOYER_DATA_ROOT=/var/lib/hermes-deployer
AGE_IDENTITY_PATH=/var/lib/hermes-deployer/master.age
# Shared HMAC secret for the short-lived deploy-WS owner tokens (spec §5).
# Generate with: openssl rand -hex 32
DEPLOYER_WS_SECRET=change-me-openssl-rand-hex-32

# --- web (apps/web) ---
HOSTNAME=127.0.0.1
PORT=3000
HERMES_DOMAIN=deployer.example.com
# Surface the worker WS to the browser. With single-host Caddy terminating the
# WS upgrade, leave unset to use same-origin wss on the path.
# NEXT_PUBLIC_WS_URL=wss://deployer.example.com

# --- worker (packages/deployer-worker) ---
DOCKER_SOCKET=/var/run/docker.sock
CADDY_ADMIN_URL=http://127.0.0.1:2019
CADDY_SERVER_NAME=srv0
# Fixed Hermes image — every agent runs this, cmd ["gateway","run"] (spec §4).
HERMES_IMAGE=ghcr.io/your-org/hermes:latest
# Two host ports per agent (API 8642 + dashboard 9119 inside the container).
DEPLOYER_PORT_MIN=13000
DEPLOYER_PORT_MAX=14000
DEPLOYER_CONTAINER_MEM_MB=1536
DEPLOYER_CONTAINER_CPU_MILLIS=1000
DEPLOYER_CONTAINER_TMPFS_MB=256
# Deploy/log WebSocket port (loopback-only; Caddy proxies it). 0 disables.
DEPLOYER_WS_PORT=7072
DEPLOYER_BOOT_HEALTH_TIMEOUT_MS=120000
